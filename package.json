{
  "private": true,
  "name": "mqvi-desktop",
  "version": "2.21.0",
  "description": "mqvi desktop application",
  "author": "akinalpfdn",
  "main": "dist-electron/main.js",
  "scripts": {
    "electron:dev": "concurrently \"npm run dev --prefix client\" \"npx tsc -p electron/tsconfig.json && electron .\"",
    "electron:build": "npm run build --prefix client && npx tsc -p electron/tsconfig.json && electron-builder",
    "electron:dist": "npm run electron:build",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-updater": "^6",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "concurrently": "^9",
    "electron": "42.7.0",
    "electron-builder": "^26",
    "vitest": "^4.0.18",
    "rcedit": "^5.0.2",
    "typescript": "~5.9.3"
  },
  "build": {
    "appId": "net.mqvi.app",
    "productName": "mqvi",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron",
      "client/dist",
      "icons"
    ],
    "artifactName": "mqvi-setup.${ext}",
    "publish": {
      "provider": "github",
      "owner": "akinalpfdn",
      "repo": "Mqvi"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icons/mqvi-icon.ico",
      "signAndEditExecutable": false,
      "extraResources": [
        {
          "from": "native/audio-capture.exe",
          "to": "native/audio-capture.exe"
        },
        {
          "from": "native/mqvi-game-capture.exe",
          "to": "native/mqvi-game-capture.exe"
        },
        {
          "from": "native/game-probe.exe",
          "to": "native/game-probe.exe"
        },
        {
          "from": "native/games-list.json",
          "to": "native/games-list.json"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "icons/icon.icns",
      "category": "public.app-category.social-networking",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true
    },
    "dmg": {
      "background": "build/dmg-background.png",
      "iconSize": 80,
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 140,
          "y": 210
        },
        {
          "x": 400,
          "y": 210,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "icons/mqvi-icon-512x512.png",
      "category": "Network;Chat"
    }
  }
}
