# ========================
# mqvi Server Configuration
# ========================
# Copy this file as .env and fill in the values.
# cp .env.example .env

# ─── Server ───
SERVER_HOST=0.0.0.0
SERVER_PORT=9090

# ─── Database ───
DATABASE_PATH=./data/mqvi.db

# ─── JWT ───
# IMPORTANT: Use a strong random secret in production!
# openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Encryption ───
# AES-256 key for encrypting LiveKit credentials in DB (64 hex chars = 32 bytes)
# openssl rand -hex 32
ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# ─── File Upload ───
UPLOAD_DIR=./data/uploads
UPLOAD_MAX_SIZE=26214400

# ─── CORS (optional) ───
# Additional origins, comma-separated.
# CORS_ORIGINS=https://yourdomain.com

# ─── LiveKit (optional — full self-host only) ───
# Used as auto-seed on first startup if no LiveKit instance exists in DB.
# Subsequent management is done via the admin panel. Leave empty to skip seeding.
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=devsecret
